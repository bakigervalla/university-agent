# Copy to .env and fill in. NEVER commit a real .env.

# --- LLM (OpenAI through LangChain) ---
# Required only when running the agent against a live model.
OPENAI_API_KEY=
# Override the default chat model if desired.
UNI_AGENT_MODEL=gpt-4o-mini

# --- Database ---
# SQLAlchemy URL. Defaults to a local SQLite file when unset.
UNI_AGENT_DATABASE_URL=sqlite:///university.db

# --- Execution safety limits ---
UNI_AGENT_MAX_ROWS=200
UNI_AGENT_MAX_REPAIRS=2
UNI_AGENT_QUERY_TIMEOUT_SECONDS=10

# --- Observability ---
# Local JSON traces are always written here.
UNI_AGENT_TRACE_DIR=docs/traces
# Optional LangSmith tracing (leave disabled for offline demos/tests).
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=uni-agent
